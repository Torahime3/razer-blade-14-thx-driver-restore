; VS Out Mode effect APO registration
HKCR,AudioEngine\AudioProcessingObjects\%OUT_FX_MODE_HOST_CLSID%, "FriendlyName", ,%Out_MFX_HOST_FriendlyName%
HKCR,AudioEngine\AudioProcessingObjects\%OUT_FX_MODE_HOST_CLSID%, "Copyright", ,%MfgCopyright%
HKCR,AudioEngine\AudioProcessingObjects\%OUT_FX_MODE_HOST_CLSID%, "MajorVersion", 0x00010001, 1
HKCR,AudioEngine\AudioProcessingObjects\%OUT_FX_MODE_HOST_CLSID%, "MinorVersion", 0x00010001, 1
