;===================================================================
[Version]
Signature   = "$Windows NT$"
Class       = AudioProcessingObject
ClassGuid   = {5989fce8-9cd0-467d-8a6a-5419e31529d4}
Provider    = THX
DriverVer = 05/18/2023,2.6.4.0
CatalogFile = THXRTAPO.cat
PnpLockdown = 1

[SourceDisksNames] 
1="THX APO Component Source"

[SourceDisksFiles]
THXOutAPO-AVX2-v2.6.dll=1
THXOutAPO-SSE2-v2.6.dll=1
;THXMicAPO-SSE2-v2.6.dll=1

[DestinationDirs]
DefaultDestDir = 11

[SignatureAttributes]
THXOutAPO-AVX2-v2.6.dll = SignatureAttributes.PETrust
THXOutAPO-SSE2-v2.6.dll = SignatureAttributes.PETrust
;THXMicAPO-SSE2-v2.6.dll = SignatureAttributes.PETrust

[SignatureAttributes.PETrust]
PETrust = true

[Manufacturer]
%ManufacturerName% = THXAPO_Component,NTamd64

[THXAPO_Component.NTamd64]
%THXAPO_Component_Description% = THXAPO_Component_Install_AVX2,SWC\VEN_THX&CID_THXAPO
%THXAPO_Component_Description_SSE2% = THXAPO_Component_Install_SSE2,SWC\VEN_THX&CID_THXAPO_SSE2

[THXAPO_Component_Install_SSE2]
CopyFiles = THXAPO_SSE2_CopyFiles
AddReg = COM_Registration_Common,COM_Registration_SSE2,Audio_Engine_Registration

[THXAPO_Component_Install_SSE2.Services]
AddService=,2

[THXAPO_SSE2_CopyFiles]
THXOutAPO-SSE2-v2.6.dll
;THXMicAPO-SSE2-v2.6.dll

[THXAPO_Component_Install_AVX2]
CopyFiles = THXAPO_AVX2_CopyFiles
AddReg = COM_Registration_Common,COM_Registration_AVX2,Audio_Engine_Registration

[THXAPO_AVX2_CopyFiles]
THXOutAPO-AVX2-v2.6.dll
;THXMicAPO-SSE2-v2.6.dll

[COM_Registration_Common]
HKCR,CLSID\%OUT_FX_STREAM_HOST_CLSID%,,,%Out_SFX_HOST_FriendlyName%
HKCR,CLSID\%OUT_FX_STREAM_HOST_CLSID%\InProcServer32,ThreadingModel,,"Both"

HKCR,CLSID\%OUT_FX_STREAM_OFFLOAD_CLSID%,,,%Out_SFX_OFFLOAD_FriendlyName%
HKCR,CLSID\%OUT_FX_STREAM_OFFLOAD_CLSID%\InProcServer32,ThreadingModel,,"Both"

;HKCR,CLSID\%CHAT_FX_STREAM_CLSID%,,,%Chat_SFX_FriendlyName%
;HKCR,CLSID\%CHAT_FX_STREAM_CLSID%\InProcServer32,ThreadingModel,,"Both"

HKCR,CLSID\%OUT_FX_MODE_HOST_CLSID%,,,%Out_MFX_HOST_FriendlyName%
HKCR,CLSID\%OUT_FX_MODE_HOST_CLSID%\InProcServer32,ThreadingModel,,"Both"

HKCR,CLSID\%OUT_FX_MODE_OFFLOAD_CLSID%,,,%Out_MFX_OFFLOAD_FriendlyName%
HKCR,CLSID\%OUT_FX_MODE_OFFLOAD_CLSID%\InProcServer32,ThreadingModel,,"Both"

; VS Mic Mode effect APO COM registration
;HKCR,CLSID\%MIC_FX_MODE_CLSID%,,,%Mic_MFX_FriendlyName%
;HKCR,CLSID\%MIC_FX_MODE_CLSID%\InProcServer32,,0x00020000,%%SystemRoot%%\System32\THXMicAPO-SSE2-v%Generation%.dll
;HKCR,CLSID\%MIC_FX_MODE_CLSID%\InProcServer32,ThreadingModel,,"Both"

[COM_Registration_AVX2]
HKCR,CLSID\%OUT_FX_STREAM_HOST_CLSID%\InProcServer32,,0x00020000,%%SystemRoot%%\System32\THXOutAPO-AVX2-v%Generation%.dll
HKCR,CLSID\%OUT_FX_STREAM_OFFLOAD_CLSID%\InProcServer32,,0x00020000,%%SystemRoot%%\System32\THXOutAPO-AVX2-v%Generation%.dll
;HKCR,CLSID\%CHAT_FX_STREAM_CLSID%\InProcServer32,,0x00020000,%%SystemRoot%%\System32\THXOutAPO-AVX2-v%Generation%.dll
HKCR,CLSID\%OUT_FX_MODE_HOST_CLSID%\InProcServer32,,0x00020000,%%SystemRoot%%\System32\THXOutAPO-AVX2-v%Generation%.dll
HKCR,CLSID\%OUT_FX_MODE_OFFLOAD_CLSID%\InProcServer32,,0x00020000,%%SystemRoot%%\System32\THXOutAPO-AVX2-v%Generation%.dll

[COM_Registration_SSE2]
HKCR,CLSID\%OUT_FX_STREAM_HOST_CLSID%\InProcServer32,,0x00020000,%%SystemRoot%%\System32\THXOutAPO-SSE2-v%Generation%.dll
HKCR,CLSID\%OUT_FX_STREAM_OFFLOAD_CLSID%\InProcServer32,,0x00020000,%%SystemRoot%%\System32\THXOutAPO-SSE2-v%Generation%.dll
;HKCR,CLSID\%CHAT_FX_STREAM_CLSID%\InProcServer32,,0x00020000,%%SystemRoot%%\System32\THXOutAPO-SSE2-v%Generation%.dll
HKCR,CLSID\%OUT_FX_MODE_HOST_CLSID%\InProcServer32,,0x00020000,%%SystemRoot%%\System32\THXOutAPO-SSE2-v%Generation%.dll
HKCR,CLSID\%OUT_FX_MODE_OFFLOAD_CLSID%\InProcServer32,,0x00020000,%%SystemRoot%%\System32\THXOutAPO-SSE2-v%Generation%.dll

[Audio_Engine_Registration]
; VS Output Stream effect APO registration
HKCR,AudioEngine\AudioProcessingObjects\%OUT_FX_STREAM_HOST_CLSID%, "FriendlyName", ,%Out_SFX_HOST_FriendlyName%
HKCR,AudioEngine\AudioProcessingObjects\%OUT_FX_STREAM_HOST_CLSID%, "Copyright", ,%MfgCopyright%
HKCR,AudioEngine\AudioProcessingObjects\%OUT_FX_STREAM_HOST_CLSID%, "MajorVersion", 0x00010001, 1
HKCR,AudioEngine\AudioProcessingObjects\%OUT_FX_STREAM_HOST_CLSID%, "MinorVersion", 0x00010001, 1
HKCR,AudioEngine\AudioProcessingObjects\%OUT_FX_STREAM_HOST_CLSID%, "Flags", 0x00010001, %VSOUTPUTAPOSFXHOST_FLAGS%
HKCR,AudioEngine\AudioProcessingObjects\%OUT_FX_STREAM_HOST_CLSID%, "MinInputConnections", 0x00010001, 1
HKCR,AudioEngine\AudioProcessingObjects\%OUT_FX_STREAM_HOST_CLSID%, "MaxInputConnections", 0x00010001, 1
HKCR,AudioEngine\AudioProcessingObjects\%OUT_FX_STREAM_HOST_CLSID%, "MinOutputConnections", 0x00010001, 1
HKCR,AudioEngine\AudioProcessingObjects\%OUT_FX_STREAM_HOST_CLSID%, "MaxOutputConnections", 0x00010001, 1
HKCR,AudioEngine\AudioProcessingObjects\%OUT_FX_STREAM_HOST_CLSID%, "MaxInstances", 0x00010001, 0xffffffff
HKCR,AudioEngine\AudioProcessingObjects\%OUT_FX_STREAM_HOST_CLSID%, "NumAPOInterfaces", 0x00010001, 1
HKCR,AudioEngine\AudioProcessingObjects\%OUT_FX_STREAM_HOST_CLSID%, "APOInterface0", ,"{FD7F2B29-24D0-4B5C-B177-592C39F9CA10}"

HKCR,AudioEngine\AudioProcessingObjects\%OUT_FX_STREAM_OFFLOAD_CLSID%, "FriendlyName", ,%Out_SFX_OFFLOAD_FriendlyName%
HKCR,AudioEngine\AudioProcessingObjects\%OUT_FX_STREAM_OFFLOAD_CLSID%, "Copyright", ,%MfgCopyright%
HKCR,AudioEngine\AudioProcessingObjects\%OUT_FX_STREAM_OFFLOAD_CLSID%, "MajorVersion", 0x00010001, 1
HKCR,AudioEngine\AudioProcessingObjects\%OUT_FX_STREAM_OFFLOAD_CLSID%, "MinorVersion", 0x00010001, 1
HKCR,AudioEngine\AudioProcessingObjects\%OUT_FX_STREAM_OFFLOAD_CLSID%, "Flags", 0x00010001, %VSOUTPUTAPOSFXOFFLOAD_FLAGS%
HKCR,AudioEngine\AudioProcessingObjects\%OUT_FX_STREAM_OFFLOAD_CLSID%, "MinInputConnections", 0x00010001, 1
HKCR,AudioEngine\AudioProcessingObjects\%OUT_FX_STREAM_OFFLOAD_CLSID%, "MaxInputConnections", 0x00010001, 1
HKCR,AudioEngine\AudioProcessingObjects\%OUT_FX_STREAM_OFFLOAD_CLSID%, "MinOutputConnections", 0x00010001, 1
HKCR,AudioEngine\AudioProcessingObjects\%OUT_FX_STREAM_OFFLOAD_CLSID%, "MaxOutputConnections", 0x00010001, 1
HKCR,AudioEngine\AudioProcessingObjects\%OUT_FX_STREAM_OFFLOAD_CLSID%, "MaxInstances", 0x00010001, 0xffffffff
HKCR,AudioEngine\AudioProcessingObjects\%OUT_FX_STREAM_OFFLOAD_CLSID%, "NumAPOInterfaces", 0x00010001, 1
HKCR,AudioEngine\AudioProcessingObjects\%OUT_FX_STREAM_OFFLOAD_CLSID%, "APOInterface0", ,"{FD7F2B29-24D0-4B5C-B177-592C39F9CA10}"

