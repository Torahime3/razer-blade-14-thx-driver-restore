;HKCR,AudioEngine\AudioProcessingObjects\%CHAT_FX_STREAM_CLSID%, "FriendlyName", ,%Chat_SFX_FriendlyName%
;HKCR,AudioEngine\AudioProcessingObjects\%CHAT_FX_STREAM_CLSID%, "Copyright", ,%MfgCopyright%
