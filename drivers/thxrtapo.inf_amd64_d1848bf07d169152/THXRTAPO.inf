[THXAPO_Component_Install_AVX2.HW]
AddReg = FriendlyName_AddReg

[FriendlyName_AddReg]
HKR,,FriendlyName,,%THXAPO_Component_FriendlyName%

[THXAPO_Component_Install_AVX2.Services]
AddService=,2    ; no function driver, install a null driver.

[Strings]
Generation = "2.6"
ManufacturerName     = "THX"
THXAPO_Component_Description = "THX Audio Processing Object Component"
THXAPO_Component_Description_SSE2 = "THX Audio Processing Object Component for pre-AVX2 x64 Architectures"
THXAPO_Component_FriendlyName = "THX Audio Processing Object Component"

MfgCopyright	     = "Copyright (c) 2021 THX Inc. All Rights Reserved"

REG_DWORD                                     = 0x00010001
REG_MULTI_SZ                                  = 0x00010000
REG_MULTI_SZ_APPEND                           = 0x00010008
REG_MULTI_SZ_DELETE                           = 0x00018002
REG_EXPAND_SZ                                 = 0x00020000
REG_BINARY_NOCLOBBER                          = 0x00030003
REG_BINARY                                    = 0x00000001

OUT_FX_STREAM_HOST_CLSID       = "{C792E395-BD30-472D-9A2F-2783D7FAF812}"
OUT_FX_STREAM_OFFLOAD_CLSID    = "{DB605787-5A21-4A87-AAB3-B0C2DF66F586}"
OUT_FX_MODE_HOST_CLSID         = "{68650828-CA0F-4196-9096-5F50931AF10A}"
OUT_FX_MODE_OFFLOAD_CLSID      = "{E6769B7D-B58F-45CA-B6F2-964B83EDCB76}"
;CHAT_FX_STREAM_CLSID           = "{C4993045-DE76-4CDA-A163-B370E30C503E}"
;MIC_FX_MODE_CLSID              = "{868989EE-5D2F-42AE-A7E4-EA830D24A684}"

; see audioenginebaseapo.idl for APO_FLAG enum values
VSOUTPUTAPOSFXHOST_FLAGS    = 0x0000000c
VSOUTPUTAPOSFXOFFLOAD_FLAGS = 0x0000000c
VSOUTPUTAPOMFXHOST_FLAGS    = 0x0000000e
VSOUTPUTAPOMFXOFFLOAD_FLAGS = 0x0000000e
;VSCHATAPOSFX_FLAGS          = 0x0000000e
;VSMICAPOMFX_FLAGS           = 0x0000000e

Out_SYSFX_FriendlyName        = "THX Spatial Audio Speaker/HP APO"
Out_SFX_HOST_FriendlyName     = "THX Spatial Audio Speaker/HP APO (host stream effect)"
Out_MFX_HOST_FriendlyName     = "THX Spatial Audio Speaker/HP APO (host mode effect)"
Out_SFX_OFFLOAD_FriendlyName  = "THX Spatial Audio Speaker/HP APO (offload stream effect)"
Out_MFX_OFFLOAD_FriendlyName  = "THX Spatial Audio Speaker/HP APO (offload mode effect)"
;Chat_SYSFX_FriendlyName       = "THX Spatial Audio Chat APO"
;Chat_SFX_FriendlyName         = "THX Spatial Audio Chat APO (stream effect)"
;Mic_SYSFX_FriendlyName        = "THX Spatial Audio Mic APO"
;Mic_MFX_FriendlyName          = "THX Spatial Audio Mic APO (mode effect)"
