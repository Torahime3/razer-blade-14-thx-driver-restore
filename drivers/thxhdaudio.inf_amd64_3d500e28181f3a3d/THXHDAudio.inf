[DeviceExtension_Install_RT_SKU_A.NT]
AddReg = PresetAddReg_RT_SKU_A, THXAPO_PresetAddReg

[DeviceExtension_Install_RT_SKU_A.NT.HW]
AddReg = FriendlyName_AddReg_RT

[DeviceExtension_Install_RT_SKU_A.NT.Components]
AddComponent = THXAPO,,THXAPO_Install
AddComponent = THXSVC,,THXSVC_Install
AddComponent = THXHSA,,THXHSA_Install
AddComponent = THXSCU,,THXSCU_Install

[DeviceExtension_Install_RT_SKU_B.NT]
AddReg = PresetAddReg_RT_SKU_B, THXAPO_PresetAddReg

[DeviceExtension_Install_RT_SKU_B.NT.HW]
AddReg = FriendlyName_AddReg_RT

[DeviceExtension_Install_RT_SKU_B.NT.Components]
AddComponent = THXAPO,,THXAPO_Install
AddComponent = THXSVC,,THXSVC_Install
AddComponent = THXHSA,,THXHSA_Install
AddComponent = THXSCU,,THXSCU_Install

[DeviceExtension_Install_RT_SKU_C.NT]
