[DeviceExtension_Install_RT_SKU_C.NT.HW]
AddReg = FriendlyName_AddReg_RT

[DeviceExtension_Install_RT_SKU_C.NT.Components]
AddComponent = THXAPO,,THXAPO_Install
AddComponent = THXSVC,,THXSVC_Install
AddComponent = THXHSA,,THXHSA_Install
AddComponent = THXSCU,,THXSCU_Install

[DeviceExtension_Install_RT_SKU_D.NT]
AddReg = PresetAddReg_RT_SKU_D, THXAPO_PresetAddReg

[DeviceExtension_Install_RT_SKU_D.NT.HW]
AddReg = FriendlyName_AddReg_RTTBT

[DeviceExtension_Install_RT_SKU_D.NT.Components]
AddComponent = THXAPO,,THXAPO_Install
; no THXSVC for TBTAPO
; no THXHSA for TBTAPO
AddComponent = THXSCU,,THXSCU_Install

[DeviceExtension_Install_RT_SKU_E.NT]
AddReg = PresetAddReg_RT_SKU_E, THXAPO_PresetAddReg

[DeviceExtension_Install_RT_SKU_E.NT.HW]
AddReg = FriendlyName_AddReg_RTTBT

[DeviceExtension_Install_RT_SKU_E.NT.Components]
AddComponent = THXAPO,,THXAPO_Install
; no THXSVC for TBTAPO
; no THXHSA for TBTAPO
AddComponent = THXSCU,,THXSCU_Install

; Atom-based Celeron, Pentium devices on HDA codec
[DeviceExtension_Install_RT_SKU_F.NT]
AddReg = PresetAddReg_RT_SKU_F, THXAPO_PresetAddReg

[DeviceExtension_Install_RT_SKU_F.NT.HW]
AddReg = FriendlyName_AddReg_RTTBT

[DeviceExtension_Install_RT_SKU_F.NT.Components]
AddComponent = THXAPO,,THXAPO_SSE2_Install
; no THXSVC for TBTAPO
; no THXHSA for TBTAPO
AddComponent = THXSCU,,THXSCU_Install

[THXAPO_Install]
ComponentIDs = VEN_THX&CID_THXAPO
Description = "THX Spatial Audio Effects Component"

[THXSVC_Install]
ComponentIDs = VEN_THX&PID_THXSVC
Description = "THX Spatial Audio Service"

[THXHSA_Install]
ComponentIDs = VEN_THX&PID_THXHSA
Description = "THX Hardware Support Application"

[THXSCU_Install]
ComponentIDs = VEN_THX&PID_THXSCU
Description = "THX Spatial Audio Configuration"

[FriendlyName_AddReg_RT]
HKR,,FriendlyName,,%ExtendedFriendlyNameRT%

[FriendlyName_AddReg_RTTBT]
HKR,,FriendlyName,,%ExtendedFriendlyNameRTTBT%

[PresetAddReg_RT_SKU_A]
;; render endpoint settings
HKR,InterfaceSetting,PrimaryLineOutTopo,%REG_MULTI_SZ_APPEND%,"OutAPO"          ;; PrimaryLineOutTopo stands for Speakers(or Redirected headphone/speaker) endpoint
HKR,InterfaceSetting,SingleLineOutTopo,%REG_MULTI_SZ_APPEND%,"OutAPO"           ;; SingleLineOutTopo stands for Speakers(or Redirected headphone/speaker) endpoint
HKR,InterfaceSetting,SecondaryLineOutTopo,%REG_MULTI_SZ_APPEND%,"HPAPO"         ;; SecondaryLineOutTopo stands for Headphone endpoint

HKR,InterfaceSetting,RearLineOutTopoSST,%REG_MULTI_SZ_APPEND%,"OutAPO"        ;; Speakers(or Redirected headphone/speaker) endpoint with audio offloading DSP supported (Intel SST) 
HKR,InterfaceSetting,RearLineOutTopoSST3,%REG_MULTI_SZ_APPEND%,"HPAPO"			;; Headphone endpoint with audio offloading DSP supported (Intel SST)

;; capture endpoint settings
HKR,InterfaceSetting,RtMicInTopo,%REG_MULTI_SZ_APPEND%,"MicAPO"
HKR,InterfaceSetting,RtMicInSSTTopo,%REG_MULTI_SZ_APPEND%,"MicAPO"

[PresetAddReg_RT_SKU_B]
;; render endpoint settings
HKR,InterfaceSetting,SingleLineOutTopo,%REG_MULTI_SZ_APPEND%,"ComboAPO"
HKR,InterfaceSetting,SecondaryLineOutTopo,%REG_MULTI_SZ_APPEND%,"HPAPO"         ;; SecondaryLineOutTopo stands for Headphone endpoint

;; capture endpoint settings
HKR,InterfaceSetting,RtMicInTopo,%REG_MULTI_SZ_APPEND%,"MicAPO"

[PresetAddReg_RT_SKU_C]
;; render endpoint settings
HKR,InterfaceSetting,PrimaryLineOutTopo,%REG_MULTI_SZ_APPEND%,"OutAPO"          ;; PrimaryLineOutTopo stands for Speakers(or Redirected headphone/speaker) endpoint
HKR,InterfaceSetting,SingleLineOutTopo,%REG_MULTI_SZ_APPEND%,"OutAPO"           ;; SingleLineOutTopo stands for Speakers(or Redirected headphone/speaker) endpoint
HKR,InterfaceSetting,SecondaryLineOutTopo,%REG_MULTI_SZ_APPEND%,"HPAPO"         ;; SecondaryLineOutTopo stands for Headphone endpoint

HKR,InterfaceSetting,RearLineOutTopoHAP,%REG_MULTI_SZ_APPEND%,"OutAPO"		;; Speakers(or Redirected headphone/speaker) endpoint with audio offloading DSP supported (AMD HAP) 
HKR,InterfaceSetting,RearLineOutTopoHAP3,%REG_MULTI_SZ_APPEND%,"HPAPO"			;; Headphone endpoint with audio offloading DSP supported (AMD HAP)

;; capture endpoint settings
HKR,InterfaceSetting,RtMicInTopo,%REG_MULTI_SZ_APPEND%,"MicAPO"
;HKR,InterfaceSetting,RtMicInSSTTopo,%REG_MULTI_SZ_APPEND%,"MicAPO"             ;; no corresponding entry for HAP? commented for now

[PresetAddReg_RT_SKU_D]
;; render endpoint settings
HKR,InterfaceSetting,PrimaryLineOutTopo,%REG_MULTI_SZ_APPEND%,"OutAPO"          ;; PrimaryLineOutTopo stands for Speakers(or Redirected headphone/speaker) endpoint
HKR,InterfaceSetting,SingleLineOutTopo,%REG_MULTI_SZ_APPEND%,"OutAPO"           ;; SingleLineOutTopo stands for Speakers(or Redirected headphone/speaker) endpoint
HKR,InterfaceSetting,SecondaryLineOutTopo,%REG_MULTI_SZ_APPEND%,"HPAPO"         ;; SecondaryLineOutTopo stands for Headphone endpoint

HKR,InterfaceSetting,RearLineOutTopoHAP,%REG_MULTI_SZ_APPEND%,"OutAPO"		;; Speakers(or Redirected headphone/speaker) endpoint with audio offloading DSP supported (AMD HAP) 
HKR,InterfaceSetting,RearLineOutTopoHAP3,%REG_MULTI_SZ_APPEND%,"HPAPO"			;; Headphone endpoint with audio offloading DSP supported (AMD HAP)

;; capture endpoint settings
HKR,InterfaceSetting,RtMicInTopo,%REG_MULTI_SZ_APPEND%,"MicAPO"
;HKR,InterfaceSetting,RtMicInSSTTopo,%REG_MULTI_SZ_APPEND%,"MicAPO"             ;; no corresponding entry for HAP? commented for now

[PresetAddReg_RT_SKU_E]
;; render endpoint settings
HKR,InterfaceSetting,PrimaryLineOutTopo,%REG_MULTI_SZ_APPEND%,"OutAPO"          ;; PrimaryLineOutTopo stands for Speakers(or Redirected headphone/speaker) endpoint
HKR,InterfaceSetting,SingleLineOutTopo,%REG_MULTI_SZ_APPEND%,"OutAPO"           ;; SingleLineOutTopo stands for Speakers(or Redirected headphone/speaker) endpoint
HKR,InterfaceSetting,SecondaryLineOutTopo,%REG_MULTI_SZ_APPEND%,"HPAPO"         ;; SecondaryLineOutTopo stands for Headphone endpoint

HKR,InterfaceSetting,RearLineOutTopoSST,%REG_MULTI_SZ_APPEND%,"OutAPO"        ;; Speakers(or Redirected headphone/speaker) endpoint with audio offloading DSP supported (Intel SST) 
HKR,InterfaceSetting,RearLineOutTopoSST3,%REG_MULTI_SZ_APPEND%,"HPAPO"			;; Headphone endpoint with audio offloading DSP supported (Intel SST)

;; capture endpoint settings
HKR,InterfaceSetting,RtMicInTopo,%REG_MULTI_SZ_APPEND%,"MicAPO"
HKR,InterfaceSetting,RtMicInSSTTopo,%REG_MULTI_SZ_APPEND%,"MicAPO"

[PresetAddReg_RT_SKU_F]
;; render endpoint settings
HKR,InterfaceSetting,PrimaryLineOutTopo,%REG_MULTI_SZ_APPEND%,"OutAPO"          ;; PrimaryLineOutTopo stands for Speakers(or Redirected headphone/speaker) endpoint
HKR,InterfaceSetting,SingleLineOutTopo,%REG_MULTI_SZ_APPEND%,"OutAPO"           ;; SingleLineOutTopo stands for Speakers(or Redirected headphone/speaker) endpoint
HKR,InterfaceSetting,SecondaryLineOutTopo,%REG_MULTI_SZ_APPEND%,"HPAPO"         ;; SecondaryLineOutTopo stands for Headphone endpoint

HKR,InterfaceSetting,RearLineOutTopoSST,%REG_MULTI_SZ_APPEND%,"OutAPO"        ;; Speakers(or Redirected headphone/speaker) endpoint with audio offloading DSP supported (Intel SST) 
HKR,InterfaceSetting,RearLineOutTopoSST3,%REG_MULTI_SZ_APPEND%,"HPAPO"			;; Headphone endpoint with audio offloading DSP supported (Intel SST)

;; capture endpoint settings
HKR,InterfaceSetting,RtMicInTopo,%REG_MULTI_SZ_APPEND%,"MicAPO"
HKR,InterfaceSetting,RtMicInSSTTopo,%REG_MULTI_SZ_APPEND%,"MicAPO"


[THXAPO_PresetAddReg]
HKR, InterfaceSetting\OutAPO\EP\0, %PKEY_THX_DEVICE_TYPE_ID%,,%THX_OUT_DEVICE_ID%
HKR, InterfaceSetting\HPAPO\EP\0, %PKEY_THX_DEVICE_TYPE_ID%,,%THX_HP_DEVICE_ID%
HKR, InterfaceSetting\ComboAPO\EP\0, %PKEY_THX_DEVICE_TYPE_ID%,,%THX_COMBO_DEVICE_ID%
HKR, InterfaceSetting\MicAPO\EP\0, %PKEY_THX_DEVICE_TYPE_ID%,,%THX_MIC_DEVICE_ID%

;; See https://docs.microsoft.com/en-us/windows-hardware/drivers/install/using-dirids for documentation on %16419%
HKR, InterfaceSetting\OutAPO\EP\0, %PKEY_THX_CONFIG_PATH%,,%16419%\THX\thx_spatial.conf.json
HKR, InterfaceSetting\HPAPO\EP\0, %PKEY_THX_CONFIG_PATH%,,%16419%\THX\thx_spatial.conf.json
HKR, InterfaceSetting\ComboAPO\EP\0, %PKEY_THX_CONFIG_PATH%,,%16419%\THX\thx_spatial.conf.json
HKR, InterfaceSetting\MicAPO\EP\0, %PKEY_THX_CONFIG_PATH%,,%16419%\THX\thx_spatial.conf.json

[THXIntelSSTDeviceInterfaceRegistration]
AddProperty = CustomBranding.Property

[CustomBranding.Property]
DeviceDetailedDescription,,,,%INTEL_SST_WITH_THX%

[THXIntelSSTDeviceInterfaceRegistration.Components]
AddComponent = THXAPO,,THXAPO_SSE2_Install
AddComponent = THXSCU,,THXSCU_ISST_SSP_Install

[THXAPO_SSE2_Install]
ComponentIDs = VEN_THX&CID_THXAPO_SSE2
Description = "THX Audio Processing Object Component for pre-AVX2 architectures."

[THXSCU_ISST_SSP_Install]
ComponentIDs = VEN_THX&PID_THXSCU_ISST_SSP
Description = "Tuned By THX Audio Configuration"

[THXIntelSSTDeviceInterfaceRegistration.HW]
AddReg = THXIntelSSTDeviceInterfaceRegistration.HW.AddReg

[THXIntelSSTDeviceInterfaceRegistration.HW.AddReg]
HKR,,FriendlyName,,%INTEL_SST_WITH_THX%

[THXIntelSSTDeviceInterfaceRegistration.interfaces]
AddInterface = %KSCATEGORY_AUDIO%, "IntCAdspTopoRender_1", THXIntelSSTDeviceInterfaceRegistration.I
AddInterface = %KSCATEGORY_TOPOLOGY%, "IntCAdspTopoRender_1", THXIntelSSTDeviceInterfaceRegistration.I
AddInterface = %KSCATEGORY_AUDIO%, "IntCAdspTopoRender_2", THXIntelSSTDeviceInterfaceRegistration.I
AddInterface = %KSCATEGORY_TOPOLOGY%, "IntCAdspTopoRender_2", THXIntelSSTDeviceInterfaceRegistration.I

[THXIntelSSTDeviceInterfaceRegistration.I]
AddReg = THXIntelSSTDeviceInterfaceRegistration.I.AddReg

[THXIntelSSTDeviceInterfaceRegistration.I.AddReg]
HKR,EP\0,%PKEY_THX_DEVICE_TYPE_ID%,,"VSCombo"
HKR,EP\0,%PKEY_THX_CONFIG_PATH%,,%16419%\THX\thx_spatial.conf.json

HKR,FX\0,%PKEY_FX_Association%,,%KSNODETYPE_ANY%
HKR,FX\0,%PKEY_FX_Association%,,%KSNODETYPE_ANY%

; Host based processing
HKR,FX\0,%PKEY_CompositeFX_StreamEffectClsid%,%REG_MULTI_SZ%,%THX_SFX_APO_HOST_CLASSID%
HKR,FX\0,%PKEY_SFX_ProcessingModes_Supported_For_Streaming%,%REG_MULTI_SZ%,%AUDIO_SIGNALPROCESSINGMODE_DEFAULT%

HKR,FX\0,%PKEY_CompositeFX_ModeEffectClsid%,%REG_MULTI_SZ%,%THX_MFX_APO_HOST_CLASSID%
HKR,FX\0,%PKEY_MFX_ProcessingModes_Supported_For_Streaming%,%REG_MULTI_SZ%,%AUDIO_SIGNALPROCESSINGMODE_DEFAULT%

; Offload based processing - e.g. long buffers
HKR,FX\0,%PKEY_CompositeFX_Offload_StreamEffectClsid%,%REG_MULTI_SZ%,%THX_SFX_APO_OFFLOAD_CLSID%
HKR,FX\0,%PKEY_SFX_Offload_ProcessingModes_Supported_For_Streaming%,%REG_MULTI_SZ%,%AUDIO_SIGNALPROCESSINGMODE_DEFAULT%

HKR,FX\0,%PKEY_CompositeFX_Offload_ModeEffectClsid%,%REG_MULTI_SZ%,%THX_MFX_APO_OFFLOAD_CLSID%
HKR,FX\0,%PKEY_MFX_Offload_ProcessingModes_Supported_For_Streaming%,%REG_MULTI_SZ%,%AUDIO_SIGNALPROCESSINGMODE_DEFAULT%

HKR,EP\0,%PKEY_AudioEndpoint_Association%,,%KSNODETYPE_ANY%
HKR,EP\0,%PKEY_AudioEndpoint_Disable_SysFx%, %REG_DWORD%, 0x00000000 ; Enable SysFX


